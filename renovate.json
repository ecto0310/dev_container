{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "archlinux"
      ],
      "versioning": "regex:^base-devel-(\\d{8}\\.\\d{1}\\.\\d+)$",
      "automerge": true
    }
  ]
}
